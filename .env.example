# ─── NuxtLayerBase — Environment Variables ───────────────────────────────────
#
# Copy this file to .env in your sub-project and fill in the values.
# Variable names follow Nuxt's runtimeConfig mapping convention:
#   NUXT_PUBLIC_<KEY>  →  runtimeConfig.public.<camelCaseKey>
#   NUXT_<KEY>         →  runtimeConfig.<camelCaseKey>  (server-only)
#
# Reference: https://nuxt.com/docs/guide/going-further/runtime-config

# ── OIDC / Duende Identity Server ────────────────────────────────────────────

# Base URL of your Identity Server (e.g. https://auth.example.com)
NUXT_PUBLIC_OIDC_ISSUER=https://your-identity-server.example.com

# Client ID registered in the Identity Server
NUXT_PUBLIC_OIDC_CLIENT_ID=your-client-id

# URI that the Identity Server will redirect to after login.
# Must match a registered redirect URI in your client configuration.
NUXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# URI that the Identity Server will redirect to after logout.
NUXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# OIDC scopes to request (space-separated)
NUXT_PUBLIC_OIDC_SCOPE=openid profile email offline_access

# Response type — use "code" for Authorization Code + PKCE (recommended)
NUXT_PUBLIC_OIDC_RESPONSE_TYPE=code

# Client secret — only required for confidential clients (server-side flows).
# Leave empty for public clients (SPA with PKCE).
NUXT_OIDC_CLIENT_SECRET=

# ── Route protection ──────────────────────────────────────────────────────────

# Comma-separated list of route prefixes that do NOT require authentication.
# The auth.global middleware will allow these routes without redirecting to login.
NUXT_PUBLIC_AUTH_PUBLIC_ROUTES=/,/about,/auth

# ── API ───────────────────────────────────────────────────────────────────────

# Base URL for API requests made via useApi().
# Exposed publicly so client-side fetch works correctly.
NUXT_PUBLIC_API_BASE_URL=https://api.example.com

# Base URL for authenticated user profile requests made via useCurrentUserProfile().
# If omitted, the layer will fall back to NUXT_PUBLIC_API_BASE_URL.
NUXT_PUBLIC_AUTH_API_BASE_URL=https://auth-api.example.com
