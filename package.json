{
  "name": "@gn2studio/nuxt-layer-base",
  "version": "1.0.0",
  "description": "Nuxt 3 Base Layer — authentication (OIDC), alert/confirm modals, Tailwind CSS, and common TypeScript types",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./nuxt.config.ts"
    },
    "./*": "./*"
  },
  "scripts": {
    "dev": "npx -y node@22.12.0 ./scripts/nuxi-compat.mjs dev playground",
    "dev:layer": "npx -y node@22.12.0 ./scripts/nuxi-compat.mjs dev",
    "generate:preview": "npx -y node@22.12.0 ./scripts/nuxi-compat.mjs generate playground",
    "package:preview": "npx -y node@22.12.0 ./scripts/prepare-preview-deploy.mjs",
    "build:preview:manual": "npm run generate:preview && npm run package:preview",
    "build": "npx -y node@22.12.0 ./scripts/nuxi-compat.mjs build"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "oidc-client-ts": "3.1.0"
  },
  "optionalDependencies": {
    "@oxc-minify/binding-win32-x64-msvc": "^0.117.0",
    "@oxc-parser/binding-win32-x64-msvc": "^0.117.0",
    "@oxc-transform/binding-win32-x64-msvc": "^0.117.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "6.14.0",
    "nuxt": "3.21.2",
    "typescript": "5.6.3"
  }
}
